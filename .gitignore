# --------------------------------------------------------------------------------
# EcoRide - .gitignore
# --------------------------------------------------------------------------------

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Composer vendor (si utilisé)
vendor/

# SQL Dumps & backups
*.sql
!docker/mysql-init/init.sql
!docker/mysql-init/seed.sql
backup/

# Screenshots / fichiers lourds
docs/screenshots/
tools/

# Environnement
.env

# PHP logs
*.log

# System files Windows / Mac
.DS_Store
Thumbs.db
nul

# Cache
*.cache
*.tmp

# Output temporaire
dist/
package.json
package-lock.json

# Uploads utilisateurs
public/uploads/
